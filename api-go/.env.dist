# Application
ENV=development
PORT=3000
APP_VERSION=dev

# Database (matches existing Lago PostgreSQL)
DATABASE_URL=postgresql://lago:changeme@db:5432/lago
DATABASE_POOL=10

# Redis (matches existing Lago Redis)
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# Security
SECRET_KEY_BASE=your-secret-key-base-here-min-64-chars

# Observability (optional)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
